{
  "name": "world-university-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "data:refresh": "node scripts/refresh-university-catalog.mjs",
    "offers:csv": "node scripts/build-offer-records-csv.mjs",
    "offers:sql": "node scripts/import-offer-records.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.18.2",
    "@cloudflare/workers-types": "^4.20260604.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "csv-parse": "^6.2.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.20.0"
  }
}
